# Stripe Integration Environment Variables
# Copy this to .env.local and fill in your actual values

# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Get this from https://dashboard.stripe.com/webhooks after creating webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Your production domain (used for download links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Email service credentials (for sendDownloadEmail)
# SENDGRID_API_KEY=your_sendgrid_key
# RESEND_API_KEY=your_resend_key
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
